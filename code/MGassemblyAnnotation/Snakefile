#==============================================================================#
#                       Snakemake Workflow (Snakefile)                         #
#==============================================================================#

# --- 1. Configuration Loading ---
# Load parameters from config.yaml
configfile: "config/config.yaml"

# --- 2. Global Variables ---
# Data and directories
ASSEMBLIES = config["assemblies_to_process"]
ASSEMBLIES_DIR = config["assemblies_dir"]
HOME_DIR = config["home_dir"]
DATA_FINAL = config["data_final"]

# Pyrodigal parameters
PYRODIGAL_OUTPUT_FORMAT = config.get("pyrodigal_output_format", "gff")
PYRODIGAL_PROCEDURE = config.get("pyrodigal_procedure", "meta")

# Containers
PYRODIGAL_CONTAINER = config["pyrodigal_container"]
HMMER_CONTAINER = config["hmmer_container"]

# PLBS scripts
PLBS_DIR = config["plbs_dir"]
PYRODIGAL_WRAPPER = f"{PLBS_DIR}/{config['pyrodigal_wrapper_script']}"
HMM_SEARCH_WRAPPER = f"{PLBS_DIR}/{config['hmm_search_script']}"

# HMM resources
HGCA_HMM = f"{PLBS_DIR}/{config['hgca_hmm']}"
HMM_CUTOFF_TYPE = config.get("hmm_cutoff_type", "cut_tc")
RP16_LIST_PATH = f"{PLBS_DIR}/{config['rp16_list']}"
RP16_HMM_DIR = f"{PLBS_DIR}/{config['rp16_hmm_dir']}"
RP16_DOMAINS = ["arch", "bact"]

# Output file extensions and folders
ASSEMBLY_EXT = config.get("assembly_ext", ".fna")
PROTEIN_EXT = config.get("pyrodigal_protein_ext", ".faa")
GFF_EXT = config.get("pyrodigal_gff_ext", ".gff")

ANNOTATION_DIR = f"{HOME_DIR}/{DATA_FINAL}/MGassemblyAnnotation/ORFs"
HMM_OUTPUT_DIR = f"{HOME_DIR}/{DATA_FINAL}/MGassemblyAnnotation/hgcA_HMM"
RP16_OUTPUT_DIR = f"{HOME_DIR}/{DATA_FINAL}/MGassemblyAnnotation/rp16_HMM"

# --- 3. Check for locations and files before running workflow ---
# Check if assemblies directory exists
if not os.path.isdir(ASSEMBLIES_DIR):
    raise FileNotFoundError(f"Assemblies directory not found: {ASSEMBLIES_DIR}")
# Check if each assembly file exists
for assembly in ASSEMBLIES:
    assembly_path = f"{ASSEMBLIES_DIR}/{assembly}{ASSEMBLY_EXT}"
    if not os.path.isfile(assembly_path):
        raise FileNotFoundError(f"Assembly file not found: {assembly_path}")
# Check if Pyrodigal container exists
if not os.path.isfile(PYRODIGAL_CONTAINER):
    raise FileNotFoundError(f"Pyrodigal container not found: {PYRODIGAL_CONTAINER}")
# Check if HMMER container exists
if not os.path.isfile(HMMER_CONTAINER):
    raise FileNotFoundError(f"HMMER container not found: {HMMER_CONTAINER}")
# Check if Pyrodigal wrapper script exists
if not os.path.isfile(PYRODIGAL_WRAPPER):
    raise FileNotFoundError(f"Pyrodigal wrapper script not found: {PYRODIGAL_WRAPPER}")
# Check if HMM search wrapper script exists
if not os.path.isfile(HMM_SEARCH_WRAPPER):
    raise FileNotFoundError(f"HMM search wrapper script not found: {HMM_SEARCH_WRAPPER}")
# Check if PLBS directory exists
if not os.path.isdir(PLBS_DIR):
    raise FileNotFoundError(f"PLBS directory not found: {PLBS_DIR}")
# Check if hgcA HMM file exists
if not os.path.isfile(HGCA_HMM):
    raise FileNotFoundError(f"hgcA HMM file not found: {HGCA_HMM}")
# Check if rp16 list exists and load protein names
if not os.path.isfile(RP16_LIST_PATH):
    raise FileNotFoundError(f"rp16 list not found: {RP16_LIST_PATH}")
with open(RP16_LIST_PATH) as _f:
    RP16_PROTEINS = [line.strip() for line in _f if line.strip()]
if not RP16_PROTEINS:
    raise ValueError(f"rp16 list is empty: {RP16_LIST_PATH}")
# Check if rp16 HMM directory exists
if not os.path.isdir(RP16_HMM_DIR):
    raise FileNotFoundError(f"rp16 HMM directory not found: {RP16_HMM_DIR}")

# --- 4. Rule All ---
rule all:
    input:
        expand(f"{ANNOTATION_DIR}/{{assembly}}{PROTEIN_EXT}", assembly=ASSEMBLIES),
        expand(f"{ANNOTATION_DIR}/{{assembly}}{GFF_EXT}", assembly=ASSEMBLIES),
        expand(f"{HMM_OUTPUT_DIR}/{{assembly}}__hgcA.hmm_hits.faa", assembly=ASSEMBLIES),
        expand(f"{RP16_OUTPUT_DIR}/{{assembly}}__{{rp}}_{{domain}}.hmm_hits.faa",
               assembly=ASSEMBLIES, rp=RP16_PROTEINS, domain=RP16_DOMAINS)

# --- 5. Rule to annotate ORFs using Pyrodigal ---
rule annotate_assembly_orfs_pyrodigal:
    input:
        assembly=lambda wc: f"{ASSEMBLIES_DIR}/{wc.assembly}{ASSEMBLY_EXT}"
    output:
        protein=f"{ANNOTATION_DIR}/{{assembly}}{PROTEIN_EXT}",
        gff=f"{ANNOTATION_DIR}/{{assembly}}{GFF_EXT}"
    threads: 1
    shell:
        """
        mkdir -p "{ANNOTATION_DIR}" &&
        apptainer exec \
            -B "{ASSEMBLIES_DIR}:{ASSEMBLIES_DIR}" \
            -B "{HOME_DIR}:{HOME_DIR}" \
            -B "{PLBS_DIR}:{PLBS_DIR}" \
            "{PYRODIGAL_CONTAINER}" \
            python "{PYRODIGAL_WRAPPER}" \
                --input-assemblies "{input.assembly}" \
                --output-dir "{ANNOTATION_DIR}" \
                --output-format "{PYRODIGAL_OUTPUT_FORMAT}" \
                --procedure "{PYRODIGAL_PROCEDURE}" \
                --protein-ext "{PROTEIN_EXT}" \
                --gff-ext "{GFF_EXT}"
        """

# --- 6. Rule to search for hgcA using HMM ---
rule search_hgca_hmm:
    input:
        protein=f"{ANNOTATION_DIR}/{{assembly}}{PROTEIN_EXT}"
    output:
        hits_faa=f"{HMM_OUTPUT_DIR}/{{assembly}}__hgcA.hmm_hits.faa"
    threads: 4
    shell:
        """
        mkdir -p "{HMM_OUTPUT_DIR}" &&
        apptainer exec \
            -B "{ANNOTATION_DIR}:{ANNOTATION_DIR}" \
            -B "{HMM_OUTPUT_DIR}:{HMM_OUTPUT_DIR}" \
            -B "{PLBS_DIR}:{PLBS_DIR}" \
            "{HMMER_CONTAINER}" \
            python "{HMM_SEARCH_WRAPPER}" \
                --hmm-model "{HGCA_HMM}" \
                --input-aa-orfs "{input.protein}" \
                --output-dir "{HMM_OUTPUT_DIR}" \
                --cpu {threads} \
                --cut-tc \
                --output-basename "{wildcards.assembly}__hgcA"
        """

# --- 7. Rule to search for rp16 ribosomal proteins using HMM ---
rule search_rp16_hmm:
    input:
        protein=f"{ANNOTATION_DIR}/{{assembly}}{PROTEIN_EXT}"
    output:
        hits_faa=f"{RP16_OUTPUT_DIR}/{{assembly}}__{{rp}}_{{domain}}.hmm_hits.faa"
    threads: 4
    shell:
        """
        mkdir -p "{RP16_OUTPUT_DIR}" &&
        apptainer exec \
            -B "{ANNOTATION_DIR}:{ANNOTATION_DIR}" \
            -B "{RP16_OUTPUT_DIR}:{RP16_OUTPUT_DIR}" \
            -B "{PLBS_DIR}:{PLBS_DIR}" \
            "{HMMER_CONTAINER}" \
            python "{HMM_SEARCH_WRAPPER}" \
                --hmm-model "{RP16_HMM_DIR}/{wildcards.rp}_{wildcards.domain}.HMM" \
                --input-aa-orfs "{input.protein}" \
                --output-dir "{RP16_OUTPUT_DIR}" \
                --cpu {threads} \
                --cut-nc \
                --output-basename "{wildcards.assembly}__{wildcards.rp}_{wildcards.domain}"
        """

